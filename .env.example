# 数据库（Vercel Postgres 或本地 PostgreSQL）
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# 摘要 LLM：默认 MiniMax Coding Plan
MINIMAX_API_KEY="your_minimax_coding_plan_key"

# 可选：切换摘要厂商时使用
# LLM_PROVIDER=minimax | openai | anthropic
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...

# Cron 鉴权（Vercel Cron 调用时携带）
CRON_SECRET="your_random_secret"
